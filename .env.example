# OpenTune Environment Configuration
# Copy this to .env and fill in your values

# Required for AI procedure engineering
ANTHROPIC_API_KEY=

# Optional overrides
CLAUDE_MODEL=claude-opus-4-5
OPENTUNE_VERSION=0.1.0

# Optional: override OBD serial port (real mode only)
# OBD_PORT=/dev/ttyUSB0
# OBD_BAUD=38400
# OBD_TIMEOUT=10.0

# Optional: session log directory
# SESSION_LOG_DIR=./sessions
